# Configuración de NVIDIA NIM
NVIDIA_NIM_API_KEY=""


# Configuración de OpenRouter
OPENROUTER_API_KEY=""


# Configuración de LM Studio (proveedor local, no se requiere clave de API)
LM_STUDIO_BASE_URL="http://localhost:1234/v1"


# Todas las solicitudes de modelos de Claude se asignan a estos modelos; el modelo plano es de respaldo
# Formato: tipo_de_proveedor/modelo/nombre
# Proveedores válidos: "nvidia_nim" | "open_router" | "lmstudio"
MODEL_OPUS="nvidia_nim/z-ai/glm-5.1"
MODEL_SONNET="nvidia_nim/meta/llama-3.1-70b-instruct"
MODEL_HAIKU="nvidia_nim/meta/llama-3.1-8b-instruct"
MODEL="nvidia_nim/meta/llama-3.1-70b-instruct"


# Enrutamiento automático de modelos (desactivado por defecto para compatibilidad)
AUTO_MODEL_ENABLED=true
AUTO_MODEL_DEFAULT="sonnet"
AUTO_MODEL_ALLOW_OPUS=true
AUTO_MODEL_STRIP_OVERRIDE=true
AUTO_MODEL_DEBUG=false


# Configuración del proveedor
PROVIDER_RATE_LIMIT=40
PROVIDER_RATE_WINDOW=60
PROVIDER_MAX_CONCURRENCY=5


# Tiempo de espera del cliente HTTP (segundos) para solicitudes a la API del proveedor
HTTP_READ_TIMEOUT=120
HTTP_WRITE_TIMEOUT=10
HTTP_CONNECT_TIMEOUT=2


# Plataforma de mensajería: "telegram" | "discord"
MESSAGING_PLATFORM="discord"
MESSAGING_RATE_LIMIT=1
MESSAGING_RATE_WINDOW=1


# Transcripción de notas de voz
VOICE_NOTE_ENABLED=false
# WHISPER_DEVICE: "cpu" | "cuda" | "nvidia_nim"
# - "cpu"/"cuda": Whisper de Hugging Face Transformers (offline, gratuito; instalar con: uv sync --extra voice_local)
# - "nvidia_nim": Whisper de NVIDIA NIM mediante gRPC (requiere NVIDIA_NIM_API_KEY; instalar con: uv sync --extra voice)
WHISPER_DEVICE="nvidia_nim"
# WHISPER_MODEL:
# - Para cpu/cuda: ID o nombre corto de Hugging Face (tiny, base, small, medium, large-v2, large-v3, large-v3-turbo)
# - Para nvidia_nim: modelo de NVIDIA NIM (p.ej., "nvidia/parakeet-ctc-1.1b-asr", "openai/whisper-large-v3")
# - Para nvidia_nim, por defecto se usa "openai/whisper-large-v3" para mejor rendimiento
WHISPER_MODEL="openai/whisper-large-v3"
HF_TOKEN=""


# Configuración de Telegram
TELEGRAM_BOT_TOKEN=""
ALLOWED_TELEGRAM_USER_ID=""


# Configuración de Discord
DISCORD_BOT_TOKEN=""
ALLOWED_DISCORD_CHANNELS=""


# Configuración del agente
CLAUDE_WORKSPACE="./agent_workspace"
ALLOWED_DIR=""
FAST_PREFIX_DETECTION=true
ENABLE_NETWORK_PROBE_MOCK=true
ENABLE_TITLE_GENERATION_SKIP=true
ENABLE_SUGGESTION_MODE_SKIP=true
ENABLE_FILEPATH_EXTRACTION_MOCK=true
ENABLE_MODELS_LIST_MOCK=true
